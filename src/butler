#!/data/data/com.termux/files/usr/bin/bash

SCRIPT_PATH="$(realpath "$0")"
BASE_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

source "$BASE_DIR/lib/common.sh"

COMMAND="$1"

if [ -z "$COMMAND" ] || [ "$COMMAND" = "help" ] || [ "$COMMAND" = "--help" ] || [ "$COMMAND" = "-h" ]; then
    echo "Butler Desktop $BUTLER_VERSION"
    echo
    echo "Usage:"
    echo "  butler <command>"
    echo
    echo "Commands:"
    for cmd in "$BASE_DIR"/commands/*.sh; do
        basename "$cmd" .sh
    done | sort
    exit 0
fi

COMMAND_FILE="$BASE_DIR/commands/${COMMAND}.sh"

if [ -x "$COMMAND_FILE" ]; then
    exec "$COMMAND_FILE" "${@:2}"
fi

PLUGIN_FILE="$BASE_DIR/../plugins/${COMMAND}.sh"
INSTALLED_DB="$HOME/.butler/installed.json"

if [ -x "$PLUGIN_FILE" ]; then

    if [ -f "$INSTALLED_DB" ]; then
        ENABLED=$(jq -r --arg name "$COMMAND" \
        '.[] | select(.name == $name) | .enabled' \
        "$INSTALLED_DB")

        if [ "$ENABLED" != "true" ]; then
            error "Plugin '$COMMAND' is disabled."
            exit 1
        fi
    fi

    exec "$PLUGIN_FILE" "${@:2}"
fi

error "Unknown command: $COMMAND"
exit 1
