#!/data/data/com.termux/files/usr/bin/bash

BASE_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$BASE_DIR/lib/common.sh"

case "$1" in
    install)
        exec "$BASE_DIR/commands/install.sh"
        ;;
    doctor)
        exec "$BASE_DIR/commands/doctor.sh"
        ;;
    start)
        exec "$BASE_DIR/commands/start.sh"
        ;;
    stop)
        exec "$BASE_DIR/commands/stop.sh"
        ;;
    restart)
        exec "$BASE_DIR/commands/restart.sh"
        ;;
    status)
        exec "$BASE_DIR/commands/status.sh"
        ;;
    ""|help|--help|-h)
        echo "Butler Desktop $BUTLER_VERSION"
        echo ""
        echo "Usage:"
        echo "  butler <command>"
        echo ""
        echo "Commands:"
        echo "  install"
        echo "  doctor"
        echo "  start"
        echo "  stop"
        echo "  restart"
        echo "  status"
        ;;
    *)
        error "Unknown command: $1"
        exit 1
        ;;
esac
