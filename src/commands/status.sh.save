\#!/data/data/com.termux/files/usr/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$SCRIPT_DIR/../lib/common.sh"
source "$SCRIPT_DIR/../lib/logger.sh"
source "$SCRIPT_DIR/../lib/runtime.sh"

main() {
    info "Butler Status"

    echo

    if service_running xfce; then
        success "Desktop : Running"
        echo "XFCE PID : $(get_pid xfce)"
    else
        error "Desktop : Stopped"
    fi

    if service_running dbus; then
        success "D-Bus : Running"
    else
        error "D-Bus : Stopped"
    fi

    if service_running x11; then
        success "Termux:X11 : Running"
    else
        error "Termux:X11 : Stopped"
    fi
}

main

